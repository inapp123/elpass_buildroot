+/* ---- mode config ---- */
+
+static const struct drm_mode_config_funcs el_mode_config_funcs = {
+	.fb_create = drm_gem_fb_create,
+	.atomic_check = drm_atomic_helper_check,
+	.atomic_commit = drm_atomic_helper_commit,
+};
+
+static int el_display_create_properties(struct el_display *el)
+{
+	struct drm_device *drm = &el->drm;
+
+	el->primary_dither_prop = drm_property_create_range(drm, 0, "DITHERING", 0, 1);
+	if (!el->primary_dither_prop)
+		return -ENOMEM;
+
+	el->primary_thresh_prop = drm_property_create_range(drm, 0, "PRIM_THRESH", 0, 255);
+	if (!el->primary_thresh_prop)
+		return -ENOMEM;
+
+	el->overlay_thresh_prop = drm_property_create_range(drm, 0, "THRESH", 0, 255);
+	if (!el->overlay_thresh_prop)
+		return -ENOMEM;
+
+	drm_object_attach_property(&el->primary.base, el->primary_dither_prop,
+				   EL_DITHER_DEFAULT);
+	drm_object_attach_property(&el->primary.base, el->primary_thresh_prop,
+				   EL_PRIM_THRESH_DEFAULT);
+	drm_object_attach_property(&el->overlay.base, el->overlay_thresh_prop,
+				   EL_OVL_THRESH_DEFAULT);
+
+	return 0;
+}
+
+static int el_display_kms_init(struct el_display *el)
+{
+	struct drm_device *drm = &el->drm;
+	int ret;
+
+	drm_mode_config_init(drm);
+	drm->mode_config.funcs = &el_mode_config_funcs;
+	drm->mode_config.min_width = EL_WIDTH;
+	drm->mode_config.max_width = EL_WIDTH;
+	drm->mode_config.min_height = EL_HEIGHT;
+	drm->mode_config.max_height = EL_HEIGHT;
+
+	ret = drm_universal_plane_init(drm, &el->primary, 0,
+				       &el_primary_plane_funcs,
+				       el_primary_formats,
+				       ARRAY_SIZE(el_primary_formats),
+				       NULL, DRM_PLANE_TYPE_PRIMARY, NULL);
+	if (ret)
+		return ret;
+
+	drm_plane_helper_add(&el->primary, &el_primary_helper_funcs);
+
+	ret = drm_universal_plane_init(drm, &el->overlay, 0,
+				       &el_overlay_plane_funcs,
+				       el_overlay_formats,
+				       ARRAY_SIZE(el_overlay_formats),
+				       NULL, DRM_PLANE_TYPE_OVERLAY, NULL);
+	if (ret)
+		return ret;
+
+	drm_plane_helper_add(&el->overlay, &el_overlay_helper_funcs);
+	drm_plane_create_zpos_immutable_property(&el->primary, 0);
+	drm_plane_create_zpos_immutable_property(&el->overlay, 1);
+
+	ret = el_display_create_properties(el);
+	if (ret)
+		return ret;
+
+	ret = drm_crtc_init_with_planes(drm, &el->crtc, &el->primary, &el->overlay,
+					&el_crtc_funcs, NULL);
+	if (ret)
+		return ret;
+
+	drm_crtc_helper_add(&el->crtc, &el_crtc_helper_funcs);
+
+	ret = drm_encoder_init(drm, &el->encoder, &el_encoder_funcs,
+			       DRM_MODE_ENCODER_NONE, NULL);
+	if (ret)
+		return ret;
+
+	el->encoder.possible_crtcs = drm_crtc_mask(&el->crtc);
+	drm_encoder_helper_add(&el->encoder, &el_encoder_helper_funcs);
+
+	ret = drm_connector_init(drm, &el->connector, &el_connector_funcs,
+				 DRM_MODE_CONNECTOR_Unknown);
+	if (ret)
+		return ret;
+
+	drm_connector_helper_add(&el->connector, &el_connector_helper_funcs);
+	el->connector.polled = DRM_CONNECTOR_POLL_HPD;
+
+	ret = drm_connector_attach_encoder(&el->connector, &el->encoder);
+	if (ret)
+		return ret;
+
+	ret = drm_vblank_init(drm, 1);
+	if (ret)
+		return ret;
+
+	/* defaults: primary thresh 128, overlay thresh 127, display off */
+	el->flags_cache = (EL_PRIM_THRESH_DEFAULT << EL_FLAGS_PRIM_THRESH_SHIFT) |
+			  (EL_OVL_THRESH_DEFAULT << EL_FLAGS_THRESH_SHIFT);
+	if (EL_DITHER_DEFAULT)
+		el->flags_cache |= EL_FLAGS_DITHER_EN;
+	el_flags_commit(el);
+
+	drm_mode_config_reset(drm);
+
+	return 0;
+}
