+static irqreturn_t el_vsync_irq(int irq, void *data)
+{
+	struct el_display *el = data;
+
+	drm_crtc_handle_vblank(&el->crtc);
+
+	return IRQ_HANDLED;
+}
+
+/* ---- /dev/el_dither hack ---- */
+
+static struct class *el_dither_class;
+
+static int el_dither_open(struct inode *inode, struct file *file)
+{
+	struct el_display *el = container_of(inode->i_cdev, struct el_display, chrdev);
+
+	file->private_data = el;
+	return 0;
+}
+
+static ssize_t el_dither_read(struct file *file, char __user *buf, size_t count, loff_t *ppos)
+{
+	struct el_display *el = file->private_data;
+	char kbuf[4];
+	int len;
+
+	if (*ppos != 0)
+		return 0;
+
+	len = scnprintf(kbuf, sizeof(kbuf), "%d\n", el_flags_get_dither(el) ? 1 : 0);
+	if (count < len)
+		return -EINVAL;
+
+	if (copy_to_user(buf, kbuf, len))
+		return -EFAULT;
+
+	*ppos = len;
+	return len;
+}
+
+static ssize_t el_dither_write(struct file *file, const char __user *buf,
+			       size_t count, loff_t *ppos)
+{
+	struct el_display *el = file->private_data;
+	char kbuf[8];
+	unsigned long val;
+	int ret;
+
+	if (*ppos != 0)
+		return -EINVAL;
+
+	if (count == 0 || count >= sizeof(kbuf))
+		return -EINVAL;
+
+	if (copy_from_user(kbuf, buf, count))
+		return -EFAULT;
+
+	kbuf[count] = '\0';
+	ret = kstrtoul(kbuf, 10, &val);
+	if (ret || val > 1)
+		return -EINVAL;
+
+	el_flags_update_primary(el, val, el_flags_get_prim_thresh(el));
+	el_flags_commit(el);
+
+	return count;
+}
+
+static const struct file_operations el_dither_fops = {
+	.owner = THIS_MODULE,
+	.open = el_dither_open,
+	.read = el_dither_read,
+	.write = el_dither_write,
+	.llseek = noop_llseek,
+};
+
+static int el_dither_chrdev_register(struct el_display *el)
+{
+	int ret;
+
+	ret = alloc_chrdev_region(&el->chrdev_devt, 0, 1, "el_dither");
+	if (ret)
+		return ret;
+
+	cdev_init(&el->chrdev, &el_dither_fops);
+	ret = cdev_add(&el->chrdev, el->chrdev_devt, 1);
+	if (ret)
+		goto err_unregister;
+
+	el_dither_class = class_create("el_dither");
+	if (IS_ERR(el_dither_class)) {
+		ret = PTR_ERR(el_dither_class);
+		goto err_cdev_del;
+	}
+
+	el->chrdev_device = device_create(el_dither_class, el->dev, el->chrdev_devt, el,
+					  "el_dither");
+	if (IS_ERR(el->chrdev_device)) {
+		ret = PTR_ERR(el->chrdev_device);
+		goto err_class_destroy;
+	}
+
+	return 0;
+
+err_class_destroy:
+	class_destroy(el_dither_class);
+	el_dither_class = NULL;
+err_cdev_del:
+	cdev_del(&el->chrdev);
+err_unregister:
+	unregister_chrdev_region(el->chrdev_devt, 1);
+	return ret;
+}
+
+static void el_dither_chrdev_unregister(struct el_display *el)
+{
+	device_destroy(el_dither_class, el->chrdev_devt);
+	class_destroy(el_dither_class);
+	el_dither_class = NULL;
+	cdev_del(&el->chrdev);
+	unregister_chrdev_region(el->chrdev_devt, 1);
+}
