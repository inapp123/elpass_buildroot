+static int el_display_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct el_display *el;
+	struct drm_device *drm;
+	int ret;
+
+	if (!dev->of_node)
+		return -ENODEV;
+
+	pr_info("el_display_engine: probe (%s)\n",
+		of_node_full_name(dev->of_node));
+
+	el = devm_drm_dev_alloc(dev, &el_display_driver, struct el_display, drm);
+	if (IS_ERR(el))
+		return PTR_ERR(el);
+
+	el->dev = dev;
+	platform_set_drvdata(pdev, el);
+
+	ret = dma_set_mask_and_coherent(dev, DMA_BIT_MASK(32));
+	if (ret)
+		return ret;
+
+	el->regs = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(el->regs))
+		return PTR_ERR(el->regs);
+
+	el->m00_axi_aclk = devm_clk_get(dev, "m00_axi_aclk");
+	if (IS_ERR(el->m00_axi_aclk))
+		return dev_err_probe(dev, PTR_ERR(el->m00_axi_aclk),
+				     "missing m00_axi_aclk\n");
+
+	el->pix_clk = devm_clk_get(dev, "pix_clk");
+	if (IS_ERR(el->pix_clk))
+		return dev_err_probe(dev, PTR_ERR(el->pix_clk), "missing pix_clk\n");
+
+	el->s00_axi_aclk = devm_clk_get(dev, "s00_axi_aclk");
+	if (IS_ERR(el->s00_axi_aclk))
+		return dev_err_probe(dev, PTR_ERR(el->s00_axi_aclk),
+				     "missing s00_axi_aclk\n");
+
+	ret = clk_prepare_enable(el->m00_axi_aclk);
+	if (ret)
+		return ret;
+
+	ret = clk_prepare_enable(el->pix_clk);
+	if (ret)
+		goto err_m00;
+
+	ret = clk_prepare_enable(el->s00_axi_aclk);
+	if (ret)
+		goto err_pix;
+
+	el->irq = platform_get_irq(pdev, 0);
+	if (el->irq < 0) {
+		ret = el->irq;
+		goto err_s00;
+	}
+
+	spin_lock_init(&el->reg_lock);
+
+	ret = devm_request_irq(dev, el->irq, el_vsync_irq, IRQF_TRIGGER_RISING,
+			       dev_name(dev), el);
+	if (ret)
+		goto err_s00;
+
+	drm = &el->drm;
+	ret = el_display_kms_init(el);
+	if (ret)
+		goto err_s00;
+
+	ret = drm_dev_register(drm, 0);
+	if (ret)
+		goto err_s00;
+
+	ret = el_dither_chrdev_register(el);
+	if (ret)
+		dev_warn(dev, "failed to register /dev/el_dither: %d\n", ret);
+
+	drm_fbdev_dma_setup(drm, 32);
+
+	dev_info(dev, "el_display_engine DRM driver loaded\n");
+
+	return 0;
+
+err_s00:
+	clk_disable_unprepare(el->s00_axi_aclk);
+err_pix:
+	clk_disable_unprepare(el->pix_clk);
+err_m00:
+	clk_disable_unprepare(el->m00_axi_aclk);
+	return ret;
+}
+
+static void el_display_remove(struct platform_device *pdev)
+{
+	struct el_display *el = platform_get_drvdata(pdev);
+
+	if (el->chrdev_device)
+		el_dither_chrdev_unregister(el);
+	drm_dev_unregister(&el->drm);
+	drm_atomic_helper_shutdown(&el->drm);
+	clk_disable_unprepare(el->s00_axi_aclk);
+	clk_disable_unprepare(el->pix_clk);
+	clk_disable_unprepare(el->m00_axi_aclk);
+}
+
+static void el_display_shutdown(struct platform_device *pdev)
+{
+	struct el_display *el = platform_get_drvdata(pdev);
+
+	drm_atomic_helper_shutdown(&el->drm);
+}
