// SPDX-License-Identifier: GPL-2.0+
/dts-v1/;
#include "zynq-7000.dtsi"
#include "pl.dtsi"

/ {
	model = "ArkELPass V1";
	compatible = "rhodesisland,elpass", "xlnx,zynq-7000";

	aliases {
		serial0 = &uart0;
		mmc0 = &sdhci0;
		usb0 = &usb0;
		display0 = &el_display_engine_0;
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x40000000>;
	};

	chosen {
		bootargs = "";
		stdout-path = "serial0:115200n8";
	};

	usb_phy0: phy0 {
		#phy-cells = <0>;
		compatible = "usb-nop-xceiv";
	};
};

&clkc {
	ps-clk-frequency = <50000000>;
};

&sdhci0 {
	bootph-all;
	status = "okay";
};

&sdhci1 {
	status = "okay";
};

&uart0 {
	bootph-all;
	status = "okay";
};

&uart1 {
	status = "okay";
};

&usb0 {
	status = "okay";
	dr_mode = "host";
	usb-phy = <&usb_phy0>;
};
